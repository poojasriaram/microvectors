
# ─────────────────────────────────────────────────────────────────
# Trustgrid.ai – Environment Variables
# ─────────────────────────────────────────────────────────────────
# For LOCAL dev: Copy to .env.local and fill in your values.
# For VERCEL:    Add all vars in Vercel Dashboard → Settings → Env Vars
#                then REDEPLOY for changes to take effect.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED: Browser-side analytics (Vite exposes VITE_ prefix to browser) ──
# This is used in src/lib/analytics.ts to send tracking data directly
# from the user's browser to Google Sheets via the Apps Script URL.
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# ── REQUIRED: Server-side Google Sheets (Vercel API routes) ──────────────────
# This is used by Vercel serverless functions (api/_lib/google-sheets.ts).
# No VITE_ prefix — this is only available server-side.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec

# ── REQUIRED: Email Service (Resend) ─────────────────────────────────────────
# Sign up at https://resend.com → Create API Key → paste here.
# Free plan: 100 emails/day, 3000/month — more than enough for leads.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── REQUIRED: Email Sender Address ───────────────────────────────────────────
# Must be a verified domain in Resend, OR use "onboarding@resend.dev" for testing.
# Format: "Display Name <email@domain.com>"
FROM_EMAIL=Trustgrid AI <noreply@trustgrid.ai>

# ── REQUIRED: Team Notification Email ────────────────────────────────────────
# Internal email address that receives notifications for every form submission.
TEAM_NOTIFICATION_EMAIL=team@trustgrid.ai
